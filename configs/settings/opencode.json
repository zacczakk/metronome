{
  "instructions": [
    "~/.config/opencode/AGENTS.md",
    "~/Vaults/Memory/SOUL.md",
    "~/Vaults/Memory/IDENTITY.md",
    "~/Vaults/Memory/USER.md",
    "~/Vaults/Memory/MEMORY.md"
  ],
  "model": "tux/claude-opus-4-6",
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "rm *": "deny",
      "cat *.env": "deny",
      "cat *.env.*": "deny",
      "cat */.env": "deny",
      "cat */.env.*": "deny",
      "cat */.env.example": "allow",
      "cat ~/.zshrc_secrets": "deny",
      "cat ~/.zsh_secrets": "deny",
      "rg * ~/.zsh_secrets": "deny",
      "rg * ~/.zshrc_secrets": "deny",
      "git push *": "ask",
      "git reset --hard *": "deny"
    },
    "external_directory": {
      "*": "ask",
      "~/Vaults/**": "allow",
      "~/Library/Mobile Documents/iCloud~md~obsidian/Documents/**": "allow",
      "~/Vaults/Memory/system/grooming-reports/*": "allow",
      "~/Repos/**": "allow",
      "~/.config/opencode/agents/*": "allow",
      "~/.config/opencode/skill/**": "allow",
      "~/.config/opencode/get-shit-done/templates/*": "allow",
      "~/.mcporter/**": "allow",
      "/private/tmp/**": "allow",
      "/tmp/**": "allow",
      "~/Downloads/**": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.zshrc_secrets": "deny",
      "~/.zsh_secrets": "deny",
      "~/.config/opencode/agents/*": "allow",
      "~/.config/opencode/commands/*": "allow",
      "~/.config/opencode/skill/**": "allow",
      "~/Downloads/**": "allow"
    },
    "edit": {
      "*": "allow",
      "~/Repos/**": "deny"
    }
  },
  "agent": {
    "explore": {
      "model": "tux/claude-haiku-4-5-20251001"
    }
  },
  "plugin": [
    "opencode-agent-browser",
    "opencode-cursor-oauth"
  ],
  "provider": {
    "cursor": {
      "name": "Cursor"
    },
    "uptimize-bedrock": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Uptimize Bedrock",
      "options": {
        "baseURL": "{env:UPTIMIZE_BASE_URL_PROD}/model/",
        "apiKey": "{env:UPTIMIZE_OPENAI_API_KEY_PROD}",
        "headers": {
          "openai-standard": "True"
        }
      },
      "models": {
        "eu.anthropic.claude-sonnet-4-5-20250929-v1:0": {
          "name": "Claude Sonnet 4.5"
        },
        "eu.anthropic.claude-haiku-4-5-20251001-v1:0": {
          "name": "Claude Haiku 4.5"
        }
      }
    },
    "uptimize-openai": {
      "npm": "@ai-sdk/azure",
      "name": "Uptimize OpenAI",
      "options": {
        "baseURL": "{env:UPTIMIZE_BASE_URL_PROD}/openai",
        "apiKey": "{env:UPTIMIZE_OPENAI_API_KEY_PROD}",
        "apiVersion": "2024-02-01",
        "useDeploymentBasedUrls": true
      },
      "models": {
        "gpt-51": {
          "name": "GPT-5.1"
        },
        "gpt-5-mini": {
          "name": "GPT-5 Mini"
        }
      }
    },
    "uptimize-foundry": {
      "npm": "@ai-sdk/anthropic",
      "name": "Foundry",
      "options": {
        "baseURL": "{env:ANTHROPIC_BASE_URL}/v1",
        "apiKey": "{env:ANTHROPIC_AUTH_TOKEN}",
        "headers": {
          "Authorization": "Bearer {env:ANTHROPIC_AUTH_TOKEN}"
        }
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6"
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5"
        }
      }
    },
    "tux": {
      "npm": "@ai-sdk/anthropic",
      "name": "Tux",
      "options": {
        "baseURL": "http://127.0.0.1:18080/v1",
        "apiKey": "does-not-matter"
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6"
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5"
        }
      }
    }
  }
}
