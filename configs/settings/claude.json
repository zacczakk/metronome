{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "SSL_CERT_FILE": "~/.claude/cacert.pem",
    "NODE_EXTRA_CA_CERTS": "~/.claude/cacert.pem",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1"
  },
  "permissions": {
    "allow": [
      "mcp__context7",
      "mcp__tavily",
      "WebFetch",
      "WebSearch",
      "Read",
      "Edit",
      "Create",
      "Write",
      "Grep",
      "Glob",
      "LS",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(gh:*)",
      "Bash(uv:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(trash:*)",
      "Bash(committer:*)",
      "Bash(swift build:*)",
      "Bash(swift test:*)",
      "Bash(acsync:*)",
      "Bash(basename:*)",
      "Bash(xxd:*)",
      "Bash(grep:*)"
    ],
    "deny": [
      "Delete",
      "Bash(rm:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)",
      "Bash(git restore:*)",
      "Bash(sudo:*)",
      "Bash(cat *.env:*)",
      "Bash(cat *.env.*:*)",
      "Bash(cat */.env:*)",
      "Bash(cat */.env.*:*)",
      "Bash(cat ~/.zshrc_secrets:*)"
    ]
  },
  "alwaysThinkingEnabled": true,
  "cleanupPeriodDays": 365,
  "teammateMode": "auto",
  "prefersReducedMotion": true,
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
