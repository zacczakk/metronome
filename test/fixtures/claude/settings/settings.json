{
  "env": {
    "GH_CA_BUNDLE": "~/.claude/cacert.pem",
    "SSL_CERT_FILE": "~/.claude/cacert.pem",
    "NODE_EXTRA_CA_CERTS": "~/.claude/cacert.pem",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "ENABLE_LSP_TOOL": "1",
    "ENABLE_TOOL_SEARCH": "1"
  },
  "customKey": "preserved",
  "alwaysThinkingEnabled": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo user-hook"
          }
        ]
      },
      {
        "_managed": "metronome",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/Repos/zacczakk/metronome/configs/hooks/vault-context-loader.js\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "_managed": "metronome",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "_managed": "metronome",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/Repos/zacczakk/metronome/configs/hooks/notify-claude-stop.js\"",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "_managed": "metronome",
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/Repos/zacczakk/metronome/configs/hooks/autoformat-claude.js\"",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "_managed": "metronome",
        "matcher": "idle_prompt|auth_success",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/Repos/zacczakk/metronome/configs/hooks/notify-claude.js\"",
            "async": true
          }
        ]
      }
    ]
  },
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__context7",
      "mcp__tavily",
      "WebFetch",
      "WebSearch",
      "Read",
      "Edit",
      "Create",
      "Write",
      "Grep",
      "Glob",
      "LS",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(gh:*)",
      "Bash(uv:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(trash:*)",
      "Bash(committer:*)",
      "Bash(swift build:*)",
      "Bash(swift test:*)",
      "Bash(metronome:*)",
      "Bash(basename:*)",
      "Bash(xxd:*)",
      "Bash(grep:*)",
      "Bash(obsidian:*)",
      "Bash(rtk:*)"
    ],
    "deny": [
      "Delete",
      "Bash(rm:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)",
      "Bash(git restore:*)",
      "Bash(gh repo delete:*)",
      "Bash(sudo:*)",
      "Bash(cat *.env:*)",
      "Bash(cat *.env.*:*)",
      "Bash(cat */.env:*)",
      "Bash(cat */.env.*:*)",
      "Bash(cat ~/.zshrc_secrets:*)"
    ]
  },
  "additionalDirectories": [
    "/tmp",
    "~/Vaults"
  ],
  "cleanupPeriodDays": 365,
  "teammateMode": "auto",
  "prefersReducedMotion": true,
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "gh"
    ]
  }
}
